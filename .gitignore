# ------------------------------------------
# Model Weights (Ignore large binary checkpoints)
# ------------------------------------------
services/ai/models/**/*.onnx
services/ai/models/**/*.pt
services/ai/models/**/*.pth
!services/ai/models/**/.gitkeep
# Preserve the fine-tuned plant-disease checkpoint for demo checks (approx 9MB)
!services/ai/models/plant_disease/checkpoint.pt
# Small, quantized public ViT used by the fully local presentation MVP.
!services/ai/models/crop_vit/crop_leaf_diseases_vit.onnx
# Locally fine-tuned experimental ViT; 22.2 MB and required for offline Docker.
!services/ai/models/crop_health_vit_v3/model.onnx
!services/ai/models/crop_health_dinov2_v14/model.onnx


.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini
desktop.ini.lnk
$RECYCLE.BIN/

# ------------------------------------------
# Temp & Scratch Folders
# ------------------------------------------
tmp/
temp/
.scratch/
.scratch_*
reports/
# Versioned ML evidence is a deliverable, not a transient root-level report.
!services/ai/research/reports/
!services/ai/research/reports/**
artifacts/
*.sqlite
*.sqlite3
*.db
# Local scratch dumps (do not publish)
all_code_dump.txt
GETTING_STARTED_LOCAL.md

# Local ML research inputs and transient checkpoints. Provenance manifests,
# evaluation reports, configs, and the selected ONNX model remain versioned.
services/ai/research/data/
services/ai/research/runs/
services/ai/research/.venv/
services/ai/.research-venv/

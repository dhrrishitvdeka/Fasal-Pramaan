{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "FasalPramaan Dataset Manifest",
  "type": "object",
  "required": ["version", "samples"],
  "properties": {
    "version": { "type": "string" },
    "description": { "type": "string" },
    "license": { "type": "string" },
    "samples": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "image_path", "crop", "growth_stage", "damage_labels"],
        "properties": {
          "id": { "type": "string" },
          "image_path": { "type": "string" },
          "crop": { "type": "string" },
          "growth_stage": { "type": "string" },
          "damage_labels": {
            "type": "array",
            "items": { "type": "string" }
          },
          "severity": { "type": "string" },
          "affected_area_pct": { "type": "number" },
          "split": { "type": "string", "enum": ["train", "val", "test"] }
        }
      }
    }
  }
}

# FasalPramaan AI — local development environment
# Copy to .env and adjust as needed. Never commit real secrets.

# Project
PROJECT_NAME=FasalPramaan AI
ENVIRONMENT=development
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:8085,http://127.0.0.1:8085
# Set to the Docker host LAN IP (for example 192.168.1.20) when opening the
# demo from another device. Leave localhost for a same-machine presentation.
PUBLIC_HOST=localhost

# Database (PostGIS)
# --- Local Docker (default) ---
POSTGRES_HOST=db
POSTGRES_PORT=5432
POSTGRES_USER=fasalpramaan
POSTGRES_PASSWORD=fasalpramaan_dev_only
POSTGRES_DB=fasalpramaan
DATABASE_URL=postgresql+psycopg://fasalpramaan:fasalpramaan_dev_only@db:5432/fasalpramaan
# SQLAlchemy pool (production: behind PgBouncer / Aurora)
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=50
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# Redis / Celery
REDIS_PASSWORD=redis_dev_only
REDIS_URL=redis://:redis_dev_only@redis:6379/0
CELERY_BROKER_URL=redis://:redis_dev_only@redis:6379/0
CELERY_RESULT_BACKEND=redis://:redis_dev_only@redis:6379/1
CELERY_QUEUE_DEFAULT=evaluation
CELERY_QUEUE_RECAPTURE=recapture

# JWT Authentication
JWT_SECRET_KEY=change-me-local-dev-secret-not-for-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# MinIO / S3-compatible object storage
MINIO_ENDPOINT=minio:9000
MINIO_PUBLIC_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin_dev_only
MINIO_BUCKET=fasalpramaan-evidence
MINIO_USE_SSL=false
S3_REGION=us-east-1
S3_ADDRESSING_STYLE=path
S3_BUCKET_VERSIONING=false
STORAGE_BACKEND=s3

# API
API_HOST=0.0.0.0
API_PORT=8000
API_BASE_URL=http://localhost:8000
API_V1_PREFIX=/api/v1
RATE_LIMIT_PER_MINUTE=120
RATE_LIMIT_BACKEND=memory
TRUSTED_PROXY_IPS=
MAX_UPLOAD_SIZE_MB=15
GPS_ACCURACY_LIMIT_METERS=50
PLOT_PROXIMITY_METERS=200

# AI Service
AI_SERVICE_URL=http://ai:8001
AI_SERVICE_TOKEN=local-ai-service-token-change-in-production
AI_MODEL_ADAPTER=crop_health_v4
# Roll back to the previous local checkpoint:
# AI_MODEL_ADAPTER=crop_health_v3
# Explicit rollback to the original vendored public model:
# AI_MODEL_ADAPTER=crop_vit
# Optional multi-stage quality/crop/damage pipeline for local experimentation
# AI_MODEL_ADAPTER=hierarchical
AI_ALLOW_MOCK_FALLBACK=false
AI_ENABLE_HF_CROP_VIT=false
AI_CONFIDENCE_THRESHOLD=0.55
AI_HIGH_SEVERITY_THRESHOLD=0.7
AI_REQUIRE_HUMAN_REVIEW=true

# Observability (optional — inactive until set)
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
OTEL_SERVICE_NAME=fasalpramaan-api

# Dashboard
NEXT_PUBLIC_API_BASE_URL=/backend
NEXT_PUBLIC_APP_NAME=FasalPramaan Command Centre
NEXT_PUBLIC_TAGLINE=Capture. Verify. Protect.

# Mobile (for local device testing use host machine IP)
MOBILE_API_BASE_URL=http://10.0.2.2:8000

# Notifications (development logging only)
EMAIL_PROVIDER=console
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
NOTIFICATION_FROM=noreply@fasalpramaan.local

# Seed / demo
SEED_ON_STARTUP=true
DEMO_PASSWORD=Demo@12345
